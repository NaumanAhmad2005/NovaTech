# ===========================
# NovaTech — .gitignore
# ===========================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Next.js Build Output ----
/.next/
/out/
/build/

# ---- Testing ----
/coverage/

# ---- Environment Variables ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ---- Debug Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# ---- OS Generated ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ---- Editor & IDE ----
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ---- TypeScript ----
*.tsbuildinfo
next-env.d.ts

# ---- Vercel ----
.vercel

# ---- Misc ----
*.pem
*.log
.cache/
dist/
tmp/
temp/
.turbo/
